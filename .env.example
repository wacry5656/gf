# 环境变量配置
# 将此文件复制为 .env 并填入你的 Qwen API Key

# ===== AI 模型配置 =====
QWEN_API_KEY=your_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-flash
PORT=3000

# API 超时与重试配置（毫秒）
# QWEN_TIMEOUT_MS=30000
# QWEN_STREAM_TIMEOUT_MS=60000
QWEN_TEMPERATURE=0.85
QWEN_TOP_P=0.9

# Embedding 配置（EMBEDDING_API_KEY 不填则复用 QWEN_API_KEY）
# EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ===== 记忆系统配置 =====
MEMORY_TOP_K=5
MEMORY_CORE_LIMIT=4
RECENT_MESSAGE_LIMIT=20
MEMORY_MAX_CANDIDATES=20
MEMORY_RE_RANK_CANDIDATES=20
MEMORY_SIMILARITY_THRESHOLD=0.35
MEMORY_MAX_CONTEXT_CHARS=1500

# 上下文 token 预算：硬限制 prompt 总量，降低长聊成本
CONTEXT_MAX_TOKENS=5200
CONTEXT_SYSTEM_TOKENS=1900
CONTEXT_RECENT_TOKENS=1800
CONTEXT_SINGLE_MESSAGE_TOKENS=260
CONTEXT_SUMMARY_TOKENS=360
CONTEXT_MEMORY_TOKENS=850

# 多因素重排序权重
MEMORY_SEMANTIC_WEIGHT=0.70
MEMORY_IMPORTANCE_WEIGHT=0.12
MEMORY_RECENCY_WEIGHT=0.10
MEMORY_USAGE_WEIGHT=0.08
MEMORY_KEYWORD_WEIGHT=0.16
MEMORY_KEYWORD_RECALL_THRESHOLD=0.25

# 去重阈值
MEMORY_RECALL_THRESHOLD=0.35
MEMORY_DEDUP_THRESHOLD=0.88
MEMORY_WRITE_DEDUP_THRESHOLD=0.92

# ===== 冲突更新 =====
# 是否启用事实冲突检测与自动覆盖（旧事实标记 inactive）
MEMORY_ENABLE_CONFLICT_RESOLUTION=true

# ===== 记忆过期 =====
# state 类型记忆 TTL（天），默认 7
MEMORY_STATE_TTL_DAYS=7
# plan 类型记忆 TTL（天），默认 30
MEMORY_PLAN_TTL_DAYS=30

# ===== 摘要系统 =====
MEMORY_SUMMARY_ENABLED=true
MEMORY_SUMMARY_REFRESH_COUNT=5

# ===== 人格记忆系统 =====
PERSONALITY_MEMORY_ENABLED=true
PERSONALITY_TOP_K=5
# 人格提取最小间隔（毫秒），默认10分钟
# PERSONALITY_EXTRACT_INTERVAL_MS=600000
# 触发人格提取的最低消息数
# PERSONALITY_EXTRACT_MSG_THRESHOLD=10

# ===== 调试 =====
DEBUG_MEMORY_RETRIEVAL=false

# ===== 情绪/关系敏感度 =====
# 1.0 为保守，1.65 更适合虚拟对象聊天的可见反馈
RELATIONSHIP_STATE_SENSITIVITY=1.65
EMOTION_STATE_SENSITIVITY=1.65
